# Copy to /etc/network-traffic-analyzer/capture.env and edit (installed
# automatically by install.sh if that file doesn't exist yet).
# Same variables as the Docker deployment's .env.example - see there for
# fuller explanations of each.

APP_DIR=/opt/network-traffic-analyzer
REPORTS_ROOT=/var/lib/network-traffic-analyzer/reports
ALERT_STATE_PATH=/var/lib/network-traffic-analyzer/state/alert_state.json
# Lives alongside the reports (already read-write for this service), not
# the shared state dir - only the capture service ever needs it.
GEOIP_CACHE_PATH=/var/lib/network-traffic-analyzer/reports/geoip_cache.json
# Tracks every MAC/IP ever seen so --alerts can flag a first-time device;
# also reports-local for the same reason as GEOIP_CACHE_PATH.
KNOWN_DEVICES_PATH=/var/lib/network-traffic-analyzer/reports/known_devices.json
THREAT_INTEL_CACHE_PATH=/var/lib/network-traffic-analyzer/reports/threat_intel_cache.json

# Network interface to capture on (find it with `ip -brief link`).
IFACE=eth0

# Seconds to capture per scheduled run.
CAPTURE_DURATION=300

# Seconds between the start of one capture run and the next.
INTERVAL_SECONDS=3600

# How many past run directories to retain under REPORTS_ROOT.
RETENTION_RUNS=24

# Optional BPF filter to narrow what gets captured.
# CAPTURE_FILTER=tcp port 80 or tcp port 443

# Set true to also save each run's raw packets as traffic_capture.pcap.
CAPTURE_PCAP=false

# Reverse-DNS lookups on captured IPs, used to auto-suggest device names.
RESOLVE_HOSTNAMES=true

# Off by default: looking up country/org for public IPs sends them to a
# third-party API (ip-api.com), unlike the reverse-DNS lookup above which
# only queries your own resolver. See README before enabling.
GEOIP_ENABLED=false

# Off by default: downloads a public IP blocklist from a third party
# (abuse.ch). Doesn't send any of your traffic anywhere, but it is still
# a network call out from your home server. See README.
THREAT_INTEL_ENABLED=false

# --- Alert notifications (both optional and independent) -----------------
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_NOTIFY_MIN_SEVERITY=LOW
# DASHBOARD_URL=http://homeserver.local:8080
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=
# SMTP_FROM=alerts@example.com
# SMTP_TO=you@example.com
# SMTP_USE_TLS=true
