# Copy to /etc/network-traffic-analyzer/dashboard.env and edit (installed
# automatically by install.sh if that file doesn't exist yet).

REPORTS_ROOT=/var/lib/network-traffic-analyzer/reports
ALERT_STATE_PATH=/var/lib/network-traffic-analyzer/state/alert_state.json
DEVICE_NAMES_PATH=/var/lib/network-traffic-analyzer/state/device_names.json

# Required: password to log into the dashboard. The dashboard can suppress
# security alerts and serves packet captures, so it refuses to start
# without this set. Generate one with: openssl rand -base64 24
DASHBOARD_PASSWORD=

# Recommended: signs the dashboard's login session cookie. Without it, a
# random key is generated each process start, which logs everyone out on
# every restart. Generate one with: openssl rand -hex 32
DASHBOARD_SECRET_KEY=

# Port the dashboard listens on.
PORT=8080
