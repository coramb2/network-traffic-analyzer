# Copy to .env and adjust for your home server, then `docker compose up -d`.

# Network interface to capture on (find it with `ip -brief link` on the host).
IFACE=eth0

# Seconds to capture per scheduled run.
CAPTURE_DURATION=300

# Seconds between the start of one capture run and the next.
INTERVAL_SECONDS=3600

# How many past run directories to retain under ./reports.
RETENTION_RUNS=24

# Optional BPF filter to narrow what gets captured.
# CAPTURE_FILTER=tcp port 80 or tcp port 443

# Set true to also save each run's raw packets as traffic_capture.pcap,
# openable in Wireshark/tcpdump. Off by default - adds real disk usage
# on top of the JSON/CSV/HTML summaries.
CAPTURE_PCAP=false

# Port the dashboard web UI is published on (http://<host>:<port>).
DASHBOARD_PORT=8080
