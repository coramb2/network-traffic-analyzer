# Copy to .env and adjust for your home server, then `docker compose up -d`.

# Network interface to capture on (find it with `ip -brief link` on the host).
IFACE=eth0

# Seconds to capture per scheduled run.
CAPTURE_DURATION=300

# Seconds between the start of one capture run and the next.
INTERVAL_SECONDS=3600

# How many past run directories to retain under ./reports.
RETENTION_RUNS=24

# Optional BPF filter to narrow what gets captured.
# CAPTURE_FILTER=tcp port 80 or tcp port 443

# Set true to also save each run's raw packets as traffic_capture.pcap,
# openable in Wireshark/tcpdump. Off by default - adds real disk usage
# on top of the JSON/CSV/HTML summaries.
CAPTURE_PCAP=false

# Reverse-DNS lookups on captured IPs, used to auto-suggest device names
# in the dashboard. Set false to disable (no PTR queries leave the host).
RESOLVE_HOSTNAMES=true

# Look up country/org for public IPs seen in a capture (shown in the
# dashboard's Devices panel). Off by default: unlike RESOLVE_HOSTNAMES
# above (which only queries your own configured DNS resolver), this sends
# the IP to a third-party API (ip-api.com's free tier) - only enable it if
# you're fine with that. Results are cached on disk for 30 days.
GEOIP_ENABLED=false

# Port the dashboard web UI is published on (http://<host>:<port>).
DASHBOARD_PORT=8080

# Required: password to log into the dashboard. The dashboard can suppress
# security alerts and serves packet captures, so it refuses to start
# without this set. Generate one with: openssl rand -base64 24
DASHBOARD_PASSWORD=

# Recommended: signs the dashboard's login session cookie. Without it, a
# random key is generated each container start, which logs everyone out on
# every restart. Generate one with: openssl rand -hex 32
DASHBOARD_SECRET_KEY=

# Set true only if the dashboard sits behind a reverse proxy that
# terminates TLS and sets X-Forwarded-* headers itself (see the README's
# "TLS / Reverse Proxy" section) - marks the session cookie Secure and
# trusts exactly one forwarded hop for the real client IP/scheme. Leave
# false for a bare HTTP setup, or the login throttle can be tricked by a
# spoofed X-Forwarded-For and the session cookie will never be set at all.
DASHBOARD_BEHIND_TLS_PROXY=false

# --- Alert notifications (both optional and independent) -----------------
# When a completed capture run has new alerts (past the allowlist), a
# digest is sent to whichever of these is configured. Neither is required;
# leave both blank for no notifications at all.

# Webhook URL for a digest POST of {"text": "..."} - works as-is with
# Slack/Discord/Mattermost incoming webhooks.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Lowest severity that triggers a notification: LOW, MEDIUM, or HIGH.
ALERT_NOTIFY_MIN_SEVERITY=LOW

# Included in notifications as a link back to the dashboard, if set.
# DASHBOARD_URL=http://nas.local:8080

# Email via SMTP - set SMTP_HOST and SMTP_TO at minimum to enable it.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=
# SMTP_FROM=alerts@example.com
# SMTP_TO=you@example.com
# SMTP_USE_TLS=true
