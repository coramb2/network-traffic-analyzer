# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local config (real interface names, ports, etc.) - never the template
.env

# Local-only compose override (e.g. WSL host-networking workaround)
docker-compose.override.yml

# Raw packet captures - sensitive, can be large. reports/ already covers
# the in-run ones; this also catches a stray --pcap run at the repo root.
*.pcap

# Generated reports and dashboard state - the actual runtime directories,
# not just their current file types, so a future new file extension in
# either doesn't accidentally end up trackable.
reports/
data/
*.json
*.csv
*.html
!requirements.txt
!templates/*.html

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Test data
test_captures/
pcap_files/
